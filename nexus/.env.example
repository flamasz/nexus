# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Resend
RESEND_API_KEY=your_resend_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Business Central integration spike (server-only; never expose with NEXT_PUBLIC_)
BUSINESS_CENTRAL_TENANT_ID=your_microsoft_entra_tenant_id
BUSINESS_CENTRAL_CLIENT_ID=your_business_central_app_client_id
BUSINESS_CENTRAL_CLIENT_SECRET=your_business_central_app_client_secret
BUSINESS_CENTRAL_ENVIRONMENT=sandbox
BUSINESS_CENTRAL_DEFAULT_COMPANY_ID=your_business_central_company_id
# Optional override; defaults to https://api.businesscentral.dynamics.com
BUSINESS_CENTRAL_API_BASE_URL=https://api.businesscentral.dynamics.com
